POSTGRES_USER=hygiene
POSTGRES_PASSWORD=hygiene
POSTGRES_DB=hygiene

APP_ENV=dev
APP_SECRET=change-me-long-random
JWT_SECRET=change-me-long-random

# Principal in the CFN stack trust policy (prod control plane or your SSO role ARN for local dev).
# Local Docker uses ~/.aws (SSO). Do not set empty AWS_PROFILE/AWS_* in .env — use the mount only.
TRUST_PRINCIPAL_ARN=arn:aws:iam::000000000000:root

# Public URL of API (used to build CFN ExternalId callbacks if needed)
API_PUBLIC_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:8000

# GitHub OAuth (https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Defaults to the existing GitHub login callback so one OAuth App registration can handle both login and evidence integration.
GITHUB_INTEGRATION_CALLBACK_PATH=/v1/auth/github/callback

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Restrict Google sign-in to one domain (e.g. cloud-castles.com). Leave blank to allow any Google account.
GOOGLE_ALLOWED_DOMAIN=

# GitLab OAuth (login + integrations — add both callback URLs to your GitLab app)
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
# Login callback: {API_PUBLIC_URL}/v1/auth/gitlab/callback
# Integration callback: {API_PUBLIC_URL}/v1/integrations/gitlab/callback
GITLAB_INTEGRATION_CALLBACK_PATH=/v1/integrations/gitlab/callback

# Email (Resend)
RESEND_API_KEY=

# Optional: Ed25519 signing for evidence pack checksum manifests (base64url 32-byte seed).
# Generate: python -c "import base64,os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
EVIDENCE_PACK_SIGNING_KEY=

# Immutable evidence vault (S3 Object Lock). Key layout: {prefix}/{APP_ENV}/{aws_account_id}/{date}/{report_id}.zip
# Set true when vigil-worm-storage bucket is deployed with Object Lock + versioning
EVIDENCE_VAULT_ENABLED=true
EVIDENCE_VAULT_S3_URI=s3://vigil-worm-storage/vigil
EVIDENCE_VAULT_S3_REGION=us-east-1
EVIDENCE_VAULT_OBJECT_LOCK_MODE=COMPLIANCE
EVIDENCE_VAULT_RETENTION_DAYS=365
# none | presigned (time-limited GET for auditors)
EVIDENCE_VAULT_AUDITOR_ACCESS_MODE=none

DIGEST_FROM=hygiene@example.com

# Customer-facing CloudFormation templates — publicly readable by CloudFormation in customer accounts.
# Upload from infra/cfn/ to amzn-s3-vigil (Content-Type: text/plain or text/yaml for browser "View template").
# vigil-worm-storage is evidence vault only.
# Parent stack + nested children (paths must match your S3 key prefix):
CFN_TEMPLATE_URL=https://amzn-s3-vigil.s3.us-east-1.amazonaws.com/infra/vigil-stack.yaml
CFN_REMEDIATION_TEMPLATE_URL=https://amzn-s3-vigil.s3.us-east-1.amazonaws.com/infra/vigil-remediation-ssm.yaml
CFN_REMEDIATION_SSM_TEMPLATE_URL=https://amzn-s3-vigil.s3.us-east-1.amazonaws.com/infra/vigil-remediation-ssm.yaml

# Customer SSM Automation — region where the remediation document lives.
REMEDIATION_AUTOMATION_REGION=us-east-1
REMEDIATION_SSM_DOCUMENT_NAME=Vigil-RemediationPlanExecutor
REMEDIATION_PLAN_TTL_MINUTES=60

# When false, OAuth login only links to existing users — no new org signup via GitHub/GitLab/Google.
# Set false before a locked beta funnel (prod).
ALLOW_SSO_SIGNUP=True
